; train_eval_infer.config
; 2026/06/07 (C) antillia.com
; SEREBRUM-7T segmentation
[model]
model         = "TensorFlowFlexUNet"

generator     =  False

image_width    = 512
image_height   = 512
image_channels = 3
input_normalize = True
normalization  = False
num_classes    = 9

base_filters   = 16
base_kernels   = (11,11)
num_layers     = 8
dropout_rate   = 0.05
dilation       = (1,1)

; Model compilation parameters
optimizer       = "Adam"

learning_rate  = 0.00007
clipvalue      = 0.5

; Specify "categorical_crossentropy" function to loss
; for categoraized(one-hot-encoded) mask 
loss           = "categorical_crossentropy"
metrics        = ["dice_coef_multiclass"]

show_summary   = False

[dataset]
class_name    = "ImageCategorizedMaskDataset"

[train]
epochs        = 100
batch_size    = 2


; EarlyStopping parameter
patience      = 10

metrics       = ["dice_coef_multiclass", "val_dice_coef_multiclass"]

model_dir     = "./models/"
eval_dir      = "./eval/"
images_dir    = "../../../dataset/SEREBRUM-7T/train/images/"
masks_dir     = "../../../dataset/SEREBRUM-7T/train/masks/"

create_backup  = False

; learning_rate_reducer callback parameter
learning_rate_reducer = True
reducer_factor     = 0.5
reducer_patience   = 4

epoch_change_infer     = True
epoch_change_infer_dir =  "./epoch_change_infer"
num_infer_images       = 6

; Model saving option
save_weights_only  = True

[valid]
images_dir = "../../../dataset/SEREBRUM-7T/valid/images/"
masks_dir  = "../../../dataset/SEREBRUM-7T/valid/masks/"

[test] 
images_dir = "../../../dataset/SEREBRUM-7T/test/images/"
masks_dir  = "../../../dataset/SEREBRUM-7T/test/masks/"

[infer] 
images_dir    = "./mini_test/images/"
output_dir    = "./mini_test_output/"

[infer3d] 
;Specify an images_dir which contains NIfTI or NPY files
images_dir    = "./mini_test_3d/images/"
output_dir    = "./mini_test_3d_output/"
slice_shape_order = "hwd"
slice_normalize = True
slice_resize   = (512,512)
;Specify a cv2.rotation mode as a string.
slice_rotation = "cv2.ROTATE_90_CLOCKWISE" 

mask_overlay  = True
;Specify ".mp4" or ".gif".
;video_fileformat  = ".mp4"
video_fileformat  = ".gif"

[image]
color_order = "RGB"

[mask]
mask_datatyoe    = "categorized"
mask_file_format = ".png"
; SEREBRUM-7T 1+8 classes
;          RGB colors;
rgb_map = {(0,0,0):0, (255,0,0,):1, (0,255,0):2, (0,0,255):3, (255, 255, 0):4, (0,255,255):5, (255,0,255):6, (128,128,0):7, (0,128,128):8}
                       
                      



